<?xml version='1.0' encoding='UTF-8'?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Run_Seeder</name>
        <label>Ejecutar Seeder</label>
        <locationX>176</locationX>
        <locationY>240</locationY>
        <actionName>Electra_Workshop_Data_Seeder</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>Result_Screen</targetReference>
        </connector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <nameSegment>Electra_Workshop_Data_Seeder</nameSegment>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <apiVersion>66.0</apiVersion>
    <description>Student-facing Screen Flow. Loads Electra Automotive workshop data into the org. Idempotent via Electra_Workshop_Data_Seeder.</description>
    <environments>Default</environments>
    <interviewLabel>Sembrar Datos del Taller Electra {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Seed Workshop Data</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value><stringValue>LightningFlowBuilder</stringValue></value>
    </processMetadataValues>
    <processType>Flow</processType>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <screens>
        <name>Confirm_Screen</name>
        <label>Confirmar Carga</label>
        <locationX>176</locationX>
        <locationY>120</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Run_Seeder</targetReference>
        </connector>
        <fields>
            <name>Confirm_Message</name>
            <fieldText>&lt;p&gt;&lt;strong style="font-size: 16px;"&gt;🌱 Sembrar Datos del Taller Electra&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Esto va a cargar el catálogo de Electra en este org: 5 modelos de auto (E-Cruiser, E-Sport, E-Wagon, E-Truck, E-City), 3 concesionarias en Argentina (Palermo, Córdoba, Rosario), aproximadamente 20 turnos de prueba de manejo y 3 leads de muestra (Sofía Vega, Tomás Iriarte, Camila Ruiz).&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Si los datos ya están sembrados, no se duplican (la operación es idempotente).&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;¿Listo para sembrar?&lt;/strong&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <nextOrFinishButtonLabel>Sembrar</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <screens>
        <name>Result_Screen</name>
        <label>Resultado</label>
        <locationX>176</locationX>
        <locationY>360</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>Result_Summary</name>
            <fieldText>&lt;p&gt;&lt;strong style="font-size: 14px;"&gt;Resultado de la carga:&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;{!Run_Seeder.summary}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Ya podés empezar a chatear con el agente Electra Auto Concierge.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Error_Message</name>
            <fieldText>&lt;p style="color: #c23934; font-weight: bold;"&gt;{!Run_Seeder.errorMessage}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Run_Seeder.errorMessage</leftValueReference>
                    <operator>IsNull</operator>
                    <rightValue>
                        <booleanValue>false</booleanValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <nextOrFinishButtonLabel>Listo</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
<start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Confirm_Screen</targetReference>
        </connector>
    </start>
    <status>Active</status>
    </Flow>