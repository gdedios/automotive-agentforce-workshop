        </inputAssignments>
        <inputAssignments>
            <field>Booked_By__c</field>
            <value>
                <elementReference>finalLeadId</elementReference>
            </value>
        </inputAssignments>
        <object>Test_Drive_Slot__c</object>
    </recordUpdates>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
