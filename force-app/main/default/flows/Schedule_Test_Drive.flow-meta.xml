    </recordLookups>
    <recordLookups>
        <name>Find_Available_Slot</name>
        <label>Find Available Slot</label>
        <locationX>50</locationX>
        <locationY>600</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Slot_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Vehicle_Model__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Lookup_Vehicle_Model.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Dealer__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Lookup_Dealer.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Disponible</stringValue>
            </value>
        </filters>
        <filters>
            <field>Slot_DateTime__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>requestedDateTime</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Test_Drive_Slot__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>Slot_DateTime__c</queriedFields>
        <sortField>Slot_DateTime__c</sortField>
        <sortOrder>Asc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Existing_Lead</name>
