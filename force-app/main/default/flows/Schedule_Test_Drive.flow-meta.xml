<decisions>
        <name>Model_Found</name>
        <label>Model Found?</label>
        <locationX>50</locationX>
        <locationY>240</locationY>
        <defaultConnector>
            <targetReference>Set_Model_Not_Found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Found</defaultConnectorLabel>
        <rules>
            <name>Model_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Lookup_Vehicle_Model</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Lookup_Dealer</targetReference>
            </connector>
            <label>Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Dealer_Found</name>
        <label>Dealer Found?</label>
        <locationX>50</locationX>
        <locationY>480</locationY>
        <defaultConnector>
            <targetReference>Set_Dealer_Not_Found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Found</defaultConnectorLabel>
        <rules>
            <name>Dealer_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Lookup_Dealer</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Find_Available_Slot</targetReference>
            </connector>
            <label>Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Slot_Found</name>
        <label>Slot Found?</label>
        <locationX>50</locationX>
        <locationY>720</locationY>
        <defaultConnector>
            <targetReference>Set_No_Slots</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Found</defaultConnectorLabel>
        <rules>
            <name>Slot_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Find_Available_Slot</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Confirm_Create</targetReference>
            </connector>
            <label>Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Confirm_Create</name>
        <label>Check Confirm Create</label>
        <locationX>50</locationX>
        <locationY>840</locationY>
        <defaultConnector>
            <targetReference>Set_Preview</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Preview</defaultConnectorLabel>
        <rules>
            <name>Execute_Booking</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>confirmCreate</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Parse_Customer_Name</targetReference>
            </connector>
            <label>Execute</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decide_Lead_Exists</name>
        <label>Lead Exists?</label>
        <locationX>50</locationX>
        <locationY>1320</locationY>
        <defaultConnector>
            <targetReference>Use_New_Lead_ID</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>New</defaultConnectorLabel>
        <rules>
            <name>Update_Existing_Lead</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Existing_Lead</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Lead_Fields</targetReference>
            </connector>
            <label>Existing</label>
        </rules>
    </decisions>
    <description>Schedules a test drive for a customer by finding an available slot, optionally upserting Lead + updating Test_Drive_Slot__c. Called by Electra Auto Concierge agent.</description>
    <formulas>
        <name>fx_ParseFirstName</name>
        <dataType>String</dataType>
        <expression>IF(
  CONTAINS({!customerName}, " "),
  LEFT({!customerName}, FIND(" ", {!customerName}) - 1),
  "Cliente"
)</expression>
    </formulas>
    <formulas>
        <name>fx_ParseLastName</name>
        <dataType>String</dataType>
        <expression>IF(
  CONTAINS({!customerName}, " "),
  MID({!customerName}, FIND(" ", {!customerName}) + 1, LEN({!customerName})),
  {!customerName}
)</expression>
    </formulas>
    <interviewLabel>Schedule Test Drive {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Schedule Test Drive</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Upsert_Lead</name>
        <label>Upsert Lead</label>
        <locationX>50</locationX>
        <locationY>1080</locationY>
        <connector>
            <targetReference>Get_Existing_Lead</targetReference>
        </connector>
        <inputAssignments>
            <field>Email</field>
            <value>
                <elementReference>customerEmail</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>FirstName</field>
            <value>
                <elementReference>leadFirstName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LastName</field>
            <value>
                <elementReference>leadLastName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Company</field>
            <value>
                <stringValue>Particular - {!customerName}</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LeadSource</field>
            <value>
                <stringValue>Web - Electra Concierge</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Vehicle_of_Interest__c</field>
            <value>
                <elementReference>Lookup_Vehicle_Model.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Preferred_Dealer__c</field>
            <value>
                <elementReference>Lookup_Dealer.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Test_Drive_Status__c</field>
            <value>
                <stringValue>Confirmado</stringValue>
            </value>
        </inputAssignments>
        <object>Lead</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordLookups>
        <name>Lookup_Vehicle_Model</name>
        <label>Lookup Vehicle Model</label>
        <locationX>50</locationX>
        <locationY>120</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Model_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Code__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>modelCode</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Vehicle_Model__c</object>
