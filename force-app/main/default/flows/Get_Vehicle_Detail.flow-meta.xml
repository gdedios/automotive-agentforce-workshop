    <description>Returns Spanish-language detailed spec sheet for a single vehicle model identified by code. Called by ElectraAI Auto Concierge agent.</description>
    <interviewLabel>Get Vehicle Detail {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Get Vehicle Detail</label>
